---
// SPDX-License-Identifier: Apache-2.0
import MainLayout from "@/layouts/MainLayout.astro";
import { languages, type Lang } from "@/i18n/ui";

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;

// The thesis prose lives in src/thesis/ as Markdown, one file per language.
// @ts-ignore - markdown imports
const doc =
  lang === "de"
    ? await import("../../thesis/derivation.de.md")
    : await import("../../thesis/derivation.en.md");
const Content = doc.default;

// Table of contents derived from the document's own H2 headings, so it can
// never drift from the content.
const sections = doc
  .getHeadings()
  .filter((h) => h.depth === 2)
  .map((h) => ({ id: h.slug, label: h.text }));

const title = lang === "de" ? "Herleitung" : "Derivation";
const description =
  lang === "de"
    ? "Die vollständige Herleitung des Bartl Design Patterns."
    : "The full derivation of the Bartl design pattern.";
---

<MainLayout title={title} lang={lang} description={description}>
  <div class="mx-auto max-w-7xl px-4 py-12 lg:flex lg:gap-12">
    {/* Sticky TOC - desktop */}
    <aside class="hidden shrink-0 lg:block lg:w-56">
      <nav class="sticky top-20">
        <h2
          class="text-base-content/50 mb-3 text-sm font-semibold tracking-wide uppercase"
        >
          {lang === "de" ? "Inhalt" : "Contents"}
        </h2>
        <ul class="space-y-2 text-sm">
          {
            sections.map((s) => (
              <li>
                <a
                  href={`#${s.id}`}
                  class="link link-hover text-base-content/70 hover:text-base-content"
                >
                  {s.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </aside>

    {/* Main content */}
    <article
      class="prose prose-gray dark:prose-invert mx-auto max-w-3xl lg:mx-0"
    >
      <Content />
    </article>
  </div>
</MainLayout>
